{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pricing.burn.cloud/schema.json",
  "title": "LLM Pricing Data Schema",
  "description": "Schema for LLM API pricing data (currency-keyed format v3.0)",
  "type": "object",
  "required": ["version", "updated_at", "source", "models"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (e.g., '3.0')"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "source": {
      "type": "string",
      "description": "Data source identifier"
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Model"
      }
    }
  },
  "definitions": {
    "Model": {
      "type": "object",
      "required": ["pricing", "metadata"],
      "properties": {
        "pricing": {
          "type": "object",
          "description": "Pricing keyed by currency code (e.g. USD, CNY). Each key holds the canonical price from the highest-priority official source for that currency.",
          "additionalProperties": {
            "$ref": "#/definitions/CurrencyPricing"
          }
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        }
      }
    },
    "CurrencyPricing": {
      "type": "object",
      "required": ["input_price", "output_price"],
      "description": "Pricing for a model in a specific currency, from the highest-priority official source.",
      "properties": {
        "input_price": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M input tokens"
        },
        "output_price": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M output tokens"
        },
        "cache_pricing": {
          "$ref": "#/definitions/CachePricing"
        },
        "batch_pricing": {
          "$ref": "#/definitions/BatchPricing"
        },
        "tiered_pricing": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PricingTier"
          },
          "description": "Tiered pricing (e.g. price differs by context length)"
        }
      }
    },
    "CachePricing": {
      "type": "object",
      "properties": {
        "cache_read_input_price": {
          "type": "number",
          "minimum": 0,
          "description": "Price for reading from cache per 1M tokens"
        },
        "cache_creation_input_price": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Price for creating cache entry per 1M tokens"
        }
      }
    },
    "BatchPricing": {
      "type": "object",
      "required": ["input_price", "output_price"],
      "properties": {
        "input_price": {
          "type": "number",
          "minimum": 0,
          "description": "Batch API input price per 1M tokens"
        },
        "output_price": {
          "type": "number",
          "minimum": 0,
          "description": "Batch API output price per 1M tokens"
        }
      }
    },
    "PricingTier": {
      "type": "object",
      "required": ["tier_start", "input_price", "output_price"],
      "properties": {
        "tier_start": {
          "type": "integer",
          "minimum": 0,
          "description": "Inclusive start of token range for this tier"
        },
        "tier_end": {
          "type": "integer",
          "minimum": 1,
          "description": "Exclusive end of token range (omitted for the last/open-ended tier)"
        },
        "input_price": {
          "type": "number",
          "minimum": 0,
          "description": "Input price per 1M tokens for this tier"
        },
        "output_price": {
          "type": "number",
          "minimum": 0,
          "description": "Output price per 1M tokens for this tier"
        }
      }
    },
    "Metadata": {
      "type": "object",
      "required": ["provider"],
      "properties": {
        "context_window": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum context length in tokens"
        },
        "max_output_tokens": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum output tokens"
        },
        "supports_vision": {
          "type": "boolean",
          "default": false,
          "description": "Whether model supports image input"
        },
        "supports_function_calling": {
          "type": "boolean",
          "default": false,
          "description": "Whether model supports function calling"
        },
        "supports_json_mode": {
          "type": "boolean",
          "default": false,
          "description": "Whether model supports JSON mode"
        },
        "provider": {
          "type": "string",
          "description": "Provider name (e.g., 'openai', 'anthropic', 'zhipu')"
        },
        "family": {
          "type": "string",
          "description": "Model family (e.g., 'gpt-4o', 'claude-3.5', 'qwen')"
        },
        "release_date": {
          "type": "string",
          "format": "date",
          "description": "Model release date"
        },
        "deprecated": {
          "type": "boolean",
          "default": false,
          "description": "Whether model is deprecated"
        },
        "sunset_date": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Date when deprecated model will be removed"
        }
      }
    }
  }
}
